{
  "appId": "com.databridge.ghana",
  "appName": "DataBridge",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a14"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    },
    "SplashScreen": {
      "launchShowDuration": 1000,
      "backgroundColor": "#0a0a14",
      "showSpinner": false,
      "launchAutoHide": true
    }
  },
  "android": {
    "backgroundColor": "#0a0a14",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
